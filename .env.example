# Front-end environment variables.
# Vite exposes variables prefixed with VITE_ to the client bundle.

# Backend API origin for local H5 development.
VITE_API_BASE_URL=http://localhost:3001

# Optional WeChat Open Platform website application AppID.
# Do not put an app secret in front-end environment files.
VITE_WECHAT_OPEN_APP_ID=your_wechat_open_app_id
