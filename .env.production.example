# Production H5 environment example.
# Leave VITE_API_BASE_URL empty for same-origin deployment with an Nginx /api proxy,
# or set it to a public backend origin such as https://api.example.com.

VITE_API_BASE_URL=https://your-domain.com

# Optional WeChat Open Platform website application AppID.
VITE_WECHAT_OPEN_APP_ID=your_wechat_open_app_id
